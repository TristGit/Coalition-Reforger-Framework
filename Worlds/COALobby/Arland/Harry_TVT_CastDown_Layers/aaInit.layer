  }
  CRF_MissionDescriptor "{64425051B9B5AF67}" {
   m_sTextData "Main objective"\
   "- Destroy the bomb sites"\
   ""\
   "Side objectives"\
   "- Secure the supply caches around the island"\
   ""\
   "Shelling started early in the morning, and it will stop when you begin your offensive. You have a box of explosives to help clear the island."
