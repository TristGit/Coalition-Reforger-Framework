 userScript "	int stage = 0;"
 EOnFrame ""\
 "		if (stage > 1)"\
 "			return;"\
 "		"\
 "		bool safeStart = CRF_SafestartManager.GetInstance().GetSafestartStatus();"\
 "		"\
 "		if (safeStart && stage == 0)"\
 "			stage = 1;"\
 "		"\
 "		if (stage == 1 && !safeStart)"\
 "		{"\
 "			stage = 2;"\
 "			"\
 "			IEntity mortarEffect = GetGame().GetWorld().FindEntityByName(\"mortarEffect\");"\
 "			SCR_EntityHelper.DeleteEntityAndChildren(mortarEffect);"\
 "			"\
 "			mortarEffect = GetGame().GetWorld().FindEntityByName(\"mortarEffect2\");"\
 "			SCR_EntityHelper.DeleteEntityAndChildren(mortarEffect);"\
 "			"\
 "			mortarEffect = GetGame().GetWorld().FindEntityByName(\"mortarEffect3\");"\
 "			SCR_EntityHelper.DeleteEntityAndChildren(mortarEffect);"\
 "			"\
 "		}"\
 "		"\
 "	"
 m_aMissionDescriptors {
  CRF_MissionDescriptor "{644250503DF684C0}" {
   m_sTextData "Opfor is clearing Arland of resistance elements as it is a vital radar position. The resistance has managed to steal some assets, and are set up primarily in Beauregard. Two search and destroy bomb sites are the primary targets, but there are many small supply caches up for grabs around the island. "\
   ""\
   "INDFOR Composition: Inf"\
   "INDFOR Assets: Mortar, ZU-23"\
   ""\
