 ""\
 "	int totalSpawnPoints = 276;"\
 ""\
 "	void SpawnWeaponsAndMags()"\
 "	{"\
 "		EntitySpawnParams spawnParams = new EntitySpawnParams();"\
 "	spawnParams.TransformMode = ETransformMode.WORLD;"\
 ""\
 "		for (int i = 1; i <= totalSpawnPoints; i++)"\
 "		{"\
 "			string spawnPointName = \"weaponSpawn\" + i.ToString();"\
 "			IEntity spawnPoint = GetGame().GetWorld().FindEntityByName(spawnPointName);"\
 "			if (!spawnPoint)"\
 "			continue;"\
 ""\
 "			// spawn chance"\
 "			float chanceToSpawn = 0.60;"\
 "			if (Math.RandomFloat01() > chanceToSpawn)"\
 "				continue;"\
 ""\
 "			int idx = Math.RandomInt(0, weapons.Count());"\
 ""\
 "			spawnParams.Transform[3] = spawnPoint.GetOrigin();"\
 ""\
 "			GetGame().SpawnEntityPrefab(Resource.Load(weapons[idx]), GetGame().GetWorld(), spawnParams);"\
 "			GetGame().SpawnEntityPrefab(Resource.Load(magazines[idx]), GetGame().GetWorld(), spawnParams);"\
 "		}"\
 "	}"\
 ""\
 "	override void EOnInit(IEntity owner)"\
 "	{"\
 "		super.EOnInit(owner);"\
 "		GetGame().GetCallqueue().CallLater(SpawnWeaponsAndMags, 100, false);"\
 "	}"
 m_bAutoPlayerRespawn 1
 m_iTimeLimitMinutes 18
 m_aMissionDescriptors {
