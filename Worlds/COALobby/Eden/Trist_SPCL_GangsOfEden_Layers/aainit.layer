 coords 4341.53 4.508 10771.377
 userScript "	// Side switch on any side death to BLU"\
 "	protected override void OnControllableDestroyed(IEntity entity, IEntity killerEntity, notnull Instigator instigator)"\
 "{"\
 "        SCR_InstigatorContextData instigatorContextData = new SCR_InstigatorContextData(-1, entity, killerEntity, instigator);"\
 "        int playerId = instigatorContextData.GetVictimPlayerID();"\
 ""\
 "        CRF_SlottingManager sm = CRF_SlottingManager.GetInstance();"\
 "        CRF_SlotDataContainer slotData = sm.GetPlayerSlotData(playerId);"\
 "        if (slotData)"\
 "        {"\
 "            slotData.SetSlotFactionKey(\"BLUFOR\");"\
 "            slotData.SetSlotResource(\"{1E08ED0385C765CC}Prefabs/Characters/Factions/BLUFOR/CRF_GS_BLUFOR_TL_P.et\");"\
 "        }"\
 ""\
 "        super.OnControllableDestroyed(entity, killerEntity, instigator);"\
 "}"
 m_bAutoPlayerRespawn 1
 m_iTimeLimitMinutes 25
 m_aMissionDescriptors {
  CRF_MissionDescriptor "{644250503DF684C0}" {
   m_sTextData "Arena Looter w/ Infection"\
   ""\
   "- 3 Faction Gangs must loot around the town to kill off OTHER gangs and police"\
   "- ANY deaths are converted to more police"\
   "- Police conversion/respawn eats BLUFOR tickets (30 Tickets Total)"\
   ""\
   "Goal: A) Kill/Outlast other gangs/police"\
   ""\
   "Rules:"\
   "- NO STEALING POLICE APPAREL"\
   "- Camping Police Safe Zone means you suck eggs"
  }
  CRF_MissionDescriptor "{6442505149CF6C93}" {
   m_aFactionKeys + {
    "CIV"
   }
  }
 }
