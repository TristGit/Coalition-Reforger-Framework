 coords 926.046 0 7414.634
}
CRF_Gamemode CRF_Lobby1 : "{6A996BBFCEB37E78}Prefabs/MP/Modes/Lobby/CRF_Lobby.et" {
 components {
  SCR_InitWeatherComponent "{64427EEC0AFF43EE}" {
   m_sInitialStartingWeatherId "Dry Thunder (Overcast)"
  }
  SCR_TimeAndWeatherHandlerComponent "{64427EEC304DD9A0}" {
   m_iStartingHours 4
   m_iStartingMinutes 37
  }
 }
 coords 1938.957 376.264 7399.25
 userScript "	int stage = 0;"\
 ""\
 "	void deleteFlags()"\
 "	{"\
 "		IEntity Kushab = GetGame().GetWorld().FindEntityByName(\"EastShore\");"\
 "		SCR_EntityHelper.DeleteEntityAndChildren(Kushab);"\
 ""\
 "		IEntity North_Of_Chaman = GetGame().GetWorld().FindEntityByName(\"MeadowRidge\");"\
 "		SCR_EntityHelper.DeleteEntityAndChildren(North_Of_Chaman);"\
 ""\
 "		IEntity Shukurkalay = GetGame().GetWorld().FindEntityByName(\"WestShore\");"\
 "		SCR_EntityHelper.DeleteEntityAndChildren(Shukurkalay);"\
 ""\
 "		IEntity Spawn = GetGame().GetWorld().FindEntityByName(\"Spawn\");"\
 "		SCR_EntityHelper.DeleteEntityAndChildren(Spawn);"\
 "	}"
 EOnFrame ""\
 "		if (stage > 1)"\
 "			return;"\
 ""\
 "		bool safeStart = CRF_SafestartManager.GetInstance().GetSafestartStatus();"\
 ""\
 "		if (safeStart && stage == 0)"\
 "			stage = 1;"\
 ""\
 "		if (stage == 1 && !safeStart)"\
 "		{"\
 "			stage = 2;"\
 "			deleteFlags();"\
 "		}"\
 "	"
 m_iTimeLimitMinutes 50
 m_aMissionDescriptors {
  CRF_MissionDescriptor "{644250503DF684C0}" {
   m_sTextData "In the fight for Kolguyev someone has been financing seperatist forces; Jim Houseman disgraced former SoD who bungled the Shadow Moses Incident. A unit calling themselves FOXHOUND has been inserted onto the island with orders to end the seperatist financing. "\
   ""\
   "Do not pick up enemy equipment, and the spotter may not pick up a primary weapon."\
   ""\
   "BLUFOR Composition: Spec Ops"\
   "BLUFOR Assets: Spotter w/ a thermal"\
   ""\
   "OPFOR Composition: Inf"\
   "OPFOR Assets: Air asset, mortars"\
   ""\
   "Time: 50 Min"\
   "Weather: Night Dry Thunder Overcast"
  }
  CRF_MissionDescriptor "{64425051F2E00216}" {
   m_sTextData "Find the HVT. If you can negotiate with him bring him in alive, but if he puts up a fight, kill him. "
  }
  CRF_MissionDescriptor "{64425051B9B5AF67}" {
   m_sTextData "Defend the HVT. He must stay within the marked AO border. "
  }
  CRF_MissionDescriptor "{644250519BE30999}" {
   m_sTitle "HVT Objectives"
   m_sTextData "You are playing Jim Houseman after the Shadow Moses incident. Your \"friends\" said they saw movement on the water, and you know the Patriots are here for you. Stay within your AO border, defend yourself as well as you can, and try not to die. You want to live, first."\
   ""\
   "There's some extra equipment in the crate nearby for you. "
   m_aFactionKeys {
    "CIV"
   }
  }
  CRF_MissionDescriptor "{6442505149CF6C93}" {
  }
  CRF_MissionDescriptor "{66C918FF04825153}" {
   m_sTitle "Flare Traps"
   m_sTextData "I've made traps that shoot flares up out of the new AP mines. They create an explosion effect, a flare effect, and throw out a few pieces of light shrapnel. "
   m_aFactionKeys {
    "BLUFOR"
    "OPFOR"
    "INDFOR"
    "SPEC"
   }
  }
 }
 m_iFactionOneRatio 2
 m_sFactionOneKey "BLU"
 m_iFactionTwoRatio 3
 m_sFactionTwoKey "OPF"
