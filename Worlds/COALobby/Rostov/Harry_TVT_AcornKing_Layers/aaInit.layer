SCR_BaseTriggerEntity bluforRespawnTrigger {
 coords 4110.453 142.557 6790.987
 userScript "	int playerCount;"\
 "	int bluforCount;"\
 "	int tickets;"\
 "	"\
 "	void safeStartCheck()"\
 "	{"\
 "		CRF_GamemodeComponent safestart = CRF_GamemodeComponent.GetInstance();"\
 "		if (safestart.GetSafestartStatus() || CRF_Gamemode.GetInstance().m_GamemodeState != CRF_GamemodeState.GAME)"\
 "		{"\
 "			Print(\"CRFTEST Returning\");"\
 "			return;"\
 "		} else {"\
 "			Print(\"CRFTEST Spawning new else\");"\
 "			playerCount = GetGame().GetPlayerManager().GetPlayerCount();"\
 "			bluforCount = Math.Ceil(playerCount / 5 * 3);"\
 "			tickets = Math.Ceil(bluforCount * 0.5);"\
 "			CRF_Gamemode gm = CRF_Gamemode.GetInstance();"\
 "			gm.m_iBLUFORTickets = tickets;"\
 "		}"\
 "	}"
 EOnInit ""\
 "		super.EOnInit(owner);"\
 "		Print(\"CRFTEST Spawning new thread EONINT\");"\
 "		GetGame().GetCallqueue().CallLater(safeStartCheck, 30000, true); // Initial check after 30 seconds"\
 "	"
 TriggerShapeType Sphere
 UpdatePeriod 120
}
