$grp BaseGameTriggerEntity {
 Spawner {
  coords 3821.654 74.351 6426.164
  userScript "	bool m_bSafeStartInit = false;"\
  ""\
  "	void InitPlane()"\
  "	{"\
  "	    vector    start        = \"1000 600 9000\";"\
  "	    vector    end            = \"9000 600 1000\";"\
  "	    vector    greenLight    = \"4500 600 5500\";"\
  "	    float    angle        = 135;"\
  "	"\
  "	    vector flightData[4];"\
  "	    flightData[0] = start;        // Start point"\
  "	    flightData[2] = greenLight;    // Green light point"\
  "	    flightData[3] = end;        // End point"\
  "		"\
  "		SCR_GroupsManagerComponent groupsMan = SCR_GroupsManagerComponent.GetInstance();"\
  "		array<SCR_AIGroup> groups = {};"\
  "		groupsMan.GetAllPlayableGroups(groups);"\
  "		PlayerManager pm = GetGame().GetPlayerManager();"\
  "		array<int> players = {};"\
  "		foreach (SCR_AIGroup group: groups)"\
  "		{"\
  "			if (!group.GetFaction())"\
  "				continue;"\
  "			"\
  "			if (group.GetFaction().GetFactionKey() != \"BLUFOR\")"\
  "				continue;"\
  "			"\
  "			array<AIAgent> agents = {};"\
  "			group.GetAgents(agents);"\
  "			"\
  "			if (agents.Count() == 0)"\
  "				continue;"\
  "			"\
  "			foreach (AIAgent agent: agents)"\
  "			{"\
  "				int playerId = pm.GetPlayerIdFromControlledEntity(agent.GetControlledEntity());"\
  "				if (playerId <= 0)"\
  "					continue;"\
  "				"\
  "				players.Insert(playerId);"\
  "			}"\
  "			"\
  "		}"\
  "	"\
  "	    ref CRF_AirdropObject flight = new CRF_AirdropObject("\
  "	        \"BLUFOR\","\
  "	        \"{D35A20947FE9E130}PrefabsEditable/Auto/Props/c130.et\","\
  "	        flightData,"\
  "	        angle,"\
  "			players"\
  "	    );"\
  "	"\
  "	    CRF_AirdropManager.GetInstance().InitFlight(flight);"\
  "	"\
  "	    delete this;"\
  "	}"
  TriggerShapeType Sphere
  PeriodicQueries 1
  UpdatePeriod 5
  OnQueryFinished ""\
  "		if (!Replication.IsServer())"\
  "	    {"\
  "	        delete this;"\
  "	        return;"\
  "	    }"\
  "	"\
  "	    if (!m_bSafeStartInit)"\
  "	    {"\
  "	        m_bSafeStartInit = CRF_SafestartManager"\
  "	            .GetInstance()"\
  "	            .GetSafestartStatus();"\
  "	"\
  "	        return;"\
  "	    }"\
  "	"\
  "	    if (!CRF_SafestartManager.GetInstance().GetSafestartStatus())"\
  "	    {"\
  "	        InitPlane();"\
  "	    }"\
  "	"
 }
 OBJ1 {
  coords 4289.16 51.924 4428.583
  userScript "	ref array<IEntity> m_aVehicles = {};"\
  "	bool m_bVehiclesSearched = false;"\
  "	"\
  "	bool FindLocalVehicles(IEntity entity)"\
  "	{"\
  "		if (!Vehicle.Cast(entity))"\
  "			return true;"\
  "		"\
  "		m_aVehicles.Insert(entity);"\
  "			"\
  "		return true;"\
  "	}"\
  "	"\
  "	void ObjectiveDestroyed()"\
  "	{"\
  "		array<int> playerIds = {};"\
  "		GetGame().GetPlayerManager().GetPlayers(playerIds);"\
  "		SCR_FactionManager factionManager = SCR_FactionManager.Cast(GetGame().GetFactionManager());"\
  "		CRF_SlottingManager slottingMan = CRF_SlottingManager.GetInstance();"\
  "		array<int> playersToAirdrop = {};"\
  "		foreach (int playerId: playerIds)"\
  "		{"\
  "			Faction playerFaction = factionManager.GetPlayerFaction(playerId);"\
  "			if (!playerFaction)"\
  "				continue;"\
  "			"\
  "			if (playerFaction.GetFactionKey() != \"SPEC\")"\
  "				continue;"\
  "			"\
  "			Faction slottingFaction = slottingMan.GetPlayerSlotFaction(playerId);"\
  "			if (!slottingFaction)"\
  "				continue;"\
  "			"\
  "			if (slottingFaction.GetFactionKey() != \"BLUFOR\")"\
  "				continue;"\
  "			"\
  "			playersToAirdrop.Insert(playerId);"\
  "		}"\
  "		"\
  "		CRF_RespawnManager.GetInstance().RespawnSide(\"BLUFOR\");"\
  "		CRF_RespawnManager.GetInstance().RespawnSide(\"OPFOR\");"\
  ""\
  "		GetGame().GetCallqueue().CallLater(CreateFlight, 3000, false, playersToAirdrop);"\
  "	}"\
  "	"\
  "	void CreateFlight(array<int> players)"\
  "	{"\
  "		vector    start        = \"1000 600 9000\";"\
  "	    vector    end            = \"9000 600 1000\";"\
  "	    vector    greenLight    = \"4500 600 5500\";"\
  "	    float    angle        = 135;"\
  "	"\
  "	    vector flightData[4];"\
  "	    flightData[0] = start;        // Start point"\
  "	    flightData[2] = greenLight;    // Green light point"\
  "	    flightData[3] = end;        // End point"\
  "		"\
  "		ref CRF_AirdropObject flight = new CRF_AirdropObject("\
  "	        \"BLUFOR\","\
  "	        \"{D35A20947FE9E130}PrefabsEditable/Auto/Props/c130.et\","\
  "	        flightData,"\
  "	        angle,"\
  "			players"\
  "	    );"\
  "		"\
  "		CRF_AirdropManager.GetInstance().InitFlight(flight);	"\
  "			"\
  "		delete this;"\
  "		return;"\
  "	}"
  TriggerShapeType Sphere
  DrawShape 1
  PeriodicQueries 1
  UpdatePeriod 5
  OnQueryFinished ""\
  "		if (!Replication.IsServer())"\
  "		{"\
  "			delete this;"\
  "			return;"\
  "		}"\
  "		"\
  "		if (m_aVehicles.Count() == 0 && !m_bVehiclesSearched)"\
  "		{"\
  "			m_bVehiclesSearched = true;"\
  "			GetGame().GetWorld().QueryEntitiesBySphere(GetOrigin(), 25, FindLocalVehicles, null);"\
  "			return;"\
  "		}"\
  "		"\
  "		int destroyedVehicles = 0;"\
  "		foreach (IEntity vehicle: m_aVehicles)"\
  "		{"\
  "			if (!vehicle)"\
  "			{"\
  "				destroyedVehicles ++;"\
  "				continue;"\
  "			}"\
  "			"\
  "			SCR_VehicleDamageManagerComponent damageMan = SCR_VehicleDamageManagerComponent.Cast(vehicle.FindComponent(SCR_VehicleDamageManagerComponent));"\
  "			if (!damageMan)"\
  "			{"\
  "				destroyedVehicles ++;"\
  "				continue;"\
  "			}"\
  "			"\
  "			if (damageMan.GetState() == EDamageState.DESTROYED)"\
  "				destroyedVehicles++;"\
  "		}"\
  "		"\
  "		if (destroyedVehicles == m_aVehicles.Count())"\
  "			ObjectiveDestroyed();"\
  "	"
 }
}
