$grp CRF_MissionMarker : "{AAE0E36B0BB5FEC4}PrefabsEditable/Markers/ObjectiveMarkers/BLUFORObjectiveMarker.et" {
 {
  coords 4286.789 51.889 4428.566
  m_sDescription "Destroy 2S1 Battery"
  m_sMissionMarkerDescription "This 2S1 Battery, located just across the Ruha River, has been battering friendly forces during their assault towards this region. Destroy all 3 guns with your engineers we've allocated to you. Once these are destroyed we will be able to fly in another platoon to assist in the next battery."
  m_aMissionMarkerImages {
   "{E9C86D206B48FB4E}CRF Images/BriefingImages/Salami/HeartbreakSaddle/OBJ1.edds"
  }
 }
 {
  coords 5194.542 57.031 3868.685
  m_sDescription "Destroy 2S1 Battery"
  m_sMissionMarkerDescription "This final 2S1 Battery, located just east of the rail lines, is decently exposed. Getting close to it may be hard as most of the terrain around it is an open field. Once you've blown these 3 guns up, we can consider this operation a success."
  m_aMissionMarkerImages {
   "{B7204463D4C57541}CRF Images/BriefingImages/Salami/HeartbreakSaddle/OBJ2.edds"
  }
 }
}
