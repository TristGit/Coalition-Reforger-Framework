$grp SCR_BaseTriggerEntity {
 Extraction0 {
  coords 367.404 1.916 247.379
  userScript "	const string HVT = \"{9613738A003FBAD2}Prefabs/Characters/Factions/OPFOR/CRF_GS_OPFOR_PL_P.et\";"\
  "	bool m_bIsEntityInTrigger = false;"\
  "	bool m_bIsExtraction = false;"\
  "	ExtractionPicker_Class m_ExtractionPicker;"\
  "	int m_iExtraction = -1;"\
  "	bool m_bHasEscapePlayed = false;"\
  "	bool m_bHasHVTEscapePlayed = false;"
  EOnInit ""\
  "		m_ExtractionPicker = ExtractionPicker_Class.Cast(GetGame().GetWorld().FindEntityByName(\"ExtractionPicker\"));"\
  "		m_iExtraction = GetName().Get(10).ToInt();"\
  "	"
  TriggerShapeType Sphere
  SphereRadius 54.3
  PeriodicQueries 1
  UpdatePeriod 10
  OnQueryFinished ""\
  "		#ifdef WORKBENCH"\
  "		#else"\
  "		if (!System.IsConsoleApp())"\
  "			return;"\
  "		#endif"\
  "		"\
  "		if (m_iExtraction != m_ExtractionPicker.m_SelectedExtraction)"\
  "			return;"\
  "		"\
  "		if (!m_bHasEscapePlayed)"\
  "		{"\
  "			vector origin = GetOrigin();"\
  "			CRF_RplBroadcastManager.GetInstance().BroadcastMessage(\"The HVT is trying to escape to Khu Du!\");"\
  "			m_bHasEscapePlayed = true;"\
  "			"\
  "			"\
  "			SCR_MapMarkerManagerComponent markerManager = SCR_MapMarkerManagerComponent.GetInstance();"\
  "			SCR_MapMarkerBase marker = new SCR_MapMarkerBase();"\
  "			marker.SetType(SCR_EMapMarkerType.PLACED_CUSTOM);"\
  "			marker.SetIconEntry(SCR_EScenarioFrameworkMarkerCustom.PICK_UP2);"\
  "			marker.SetCustomText(\"Extraction\");"\
  "			marker.SetColorEntry(Color.RED);"\
  "			marker.SetWorldPos(origin[0], origin[2]);"\
  "			markerManager.InsertStaticMarker(marker, false, true);"\
  "			"\
  "			"\
  "			EntitySpawnParams params = new EntitySpawnParams();"\
  "			GetTransform(params.Transform);"\
  "			GetGame().SpawnEntityPrefab(Resource.Load(\"{0B3312C6940005B9}Prefabs/Structures/FlagPoles/RespawnPoles/OPFOR_Respawn.et\"), GetGame().GetWorld(), params);"\
  "			"\
  "			CRF_RespawnManager respawnMan = CRF_RespawnManager.GetInstance();"\
  "			GetGame().GetCallqueue().CallLater(respawnMan.RespawnAllSides, 1000, false);"\
  "		}"\
  "		"\
  "		GetGame().GetWorld().QueryEntitiesBySphere(this.GetOrigin(), 60, null, EntityCheck);"\
  "		"\
  "		"\
  "		if (!m_bIsEntityInTrigger)"\
  "			return;"\
  "		"\
  "		if (!m_bHasHVTEscapePlayed)"\
  "		{"\
  "			CRF_RplBroadcastManager.GetInstance().BroadcastMessage(\"The HVT has escaped!\");"\
  "			m_bHasHVTEscapePlayed = true;"\
  "		}"\
  "		"\
  "	}"\
  "	"\
  "	bool EntityCheck(IEntity entity)"\
  "	{"\
  "		if (entity.GetPrefabData().GetPrefabName() != HVT)"\
  "			return false;"\
  "		"\
  "		m_bIsEntityInTrigger = true;"\
  "		return true;"\
  "	"
 }
 ExtractionPicker {
  coords 1206.548 51.923 545.611
  userScript "	int m_iAmountOfExtractions = 0;"\
  "	CRF_SafestartManager m_SafestartManager;"\
  "	CRF_Gamemode m_Gamemode;"\
  "	int m_SelectedExtraction = -1;"\
  "	bool m_bHasWoHoPlayed = false;"\
  "	bool m_bHasInsertedScriptInvoker = false;"\
  "	"\
  "	void SelectExtraction()"\
  "	{"\
  "		RandomGenerator randomGen = new RandomGenerator();"\
  "		randomGen.SetSeed(System.GetTickCount());"\
  "		int random = randomGen.RandInt(0, m_iAmountOfExtractions);"\
  "		m_SelectedExtraction = random;"\
  "	}"
  EOnInit ""\
  "		m_Gamemode = CRF_Gamemode.GetInstance();"\
  "		m_SafestartManager = CRF_SafestartManager.GetInstance();"\
  "		GetGame().GetCallqueue().CallLater(PlayWoHo, 1000, true);"\
  "		#ifdef WORKBENCH"\
  "		#else"\
  "		if (!System.IsConsoleApp())"\
  "			return;"\
  "		#endif"\
  "		"\
  "		for (int i = 0; GetGame().GetWorld().FindEntityByName(\"Extraction\" + i.ToString()) != null; i++)"\
  "			m_iAmountOfExtractions++;"\
  "	}"\
  "	"\
  "	void PlayWoHo()"\
  "	{"\
  "		if (m_Gamemode.m_GamemodeState != CRF_EGamemodeState.GAME)"\
  "			return;"\
  "		if (!m_bHasWoHoPlayed)"\
  "		{"\
  "			GetGame().GetCallqueue().Remove(PlayWoHo);"\
  "			AudioSystem.PlaySound(\"{E21A3879A55E640B}Sounds/WoHo.wav\");"\
  "			m_bHasWoHoPlayed = true;"\
  "		}"\
  "	"
  TriggerShapeType Sphere
  PeriodicQueries 1
  UpdatePeriod 10
  OnQueryFinished ""\
  "		if (m_Gamemode.m_GamemodeState != CRF_EGamemodeState.GAME)"\
  "			return;"\
  "		"\
  "		if (m_SafestartManager.GetSafestartStatus())"\
  "			return;"\
  "			"\
  "		#ifdef WORKBENCH"\
  "		#else"\
  "		if (!System.IsConsoleApp())"\
  "			return;"\
  "		#endif"\
  "		"\
  "		float currentTime = GetGame().GetWorld().GetWorldTime();"\
  "		float millis = m_SafestartManager.m_iTimeMissionEnds - currentTime;"\
  "		int totalSeconds = (millis * 0.001);"\
  "		if (totalSeconds <= 1800 && m_SelectedExtraction == -1)"\
  "			SelectExtraction();"\
  "	"
 }
 ExtractionBLU {
  coords 1182.605 89.909 1842.003
