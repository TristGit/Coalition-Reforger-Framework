  "			marker.SetWorldPos(origin[0], origin[2]);"\
  "			markerManager.InsertStaticMarker(marker, false, true);"\
  "			"\
  "			"\
  "			EntitySpawnParams params = new EntitySpawnParams();"\
  "			GetTransform(params.Transform);"\
  "			GetGame().SpawnEntityPrefab(Resource.Load(\"{0B3312C6940005B9}Prefabs/Structures/FlagPoles/RespawnPoles/OPFOR_Respawn.et\"), GetGame().GetWorld(), params);"\
  "			"\
  "			CRF_RespawnManager respawnMan = CRF_RespawnManager.GetInstance();"\
  "			GetGame().GetCallqueue().CallLater(respawnMan.RespawnAllSides, 1000, false);"\
  "		}"\
  "		"\
  "		GetGame().GetWorld().QueryEntitiesBySphere(this.GetOrigin(), 60, null, EntityCheck);"\
  "		"\
  "		"\
  "		if (!m_bIsEntityInTrigger)"\
  "			return;"\
  "		"\
  "		if (!m_bHasHVTEscapePlayed)"\
  "		{"\
  "			CRF_RplBroadcastManager.GetInstance().BroadcastMessage(\"The HVT has escaped!\");"\
  "			m_bHasHVTEscapePlayed = true;"\
  "		}"\
  "		"\
  "	}"\
  "	"\
  "	bool EntityCheck(IEntity entity)"\
  "	{"\
  "		if (entity.GetPrefabData().GetPrefabName() != HVT)"\
  "			return false;"\
  "		"\
  "		m_bIsEntityInTrigger = true;"\
  "		return true;"\
  "	"
 }
}