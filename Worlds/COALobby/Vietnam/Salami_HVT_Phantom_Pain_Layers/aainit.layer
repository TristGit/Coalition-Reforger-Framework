 coords 1282.761 92.513 2696.722
 userScript "	void SetVisIdentityBigBoss(IEntity entity)"\
 "	{"\
 "		SCR_CharacterIdentityComponent identityComp = SCR_CharacterIdentityComponent.Cast(entity.FindComponent(SCR_CharacterIdentityComponent));"\
 "		VisualIdentity visIdentity = identityComp.GetIdentity().GetVisualIdentity();"\
 "		visIdentity.SetHead(\"{2E6FBF3E40B7EF7F}Prefabs/Characters/Heads/Head_Sturrock.et\");"\
 "		visIdentity.SetBody(\"{E7C1C23F782B7481}Prefabs/Characters/Basebody/BigBossBaseBody.et\");"\
 "		identityComp.CommitChanges();"\
 "		#ifdef WORKBENCH"\
 "		#else"\
 "		if (!System.IsConsoleApp())"\
 "			return;"\
 "		#endif"\
 "		EntitySpawnParams spawnParams = new EntitySpawnParams();"\
 "		entity.GetTransform(spawnParams.Transform);"\
 "		IEntity resourceSpawned = GetGame().SpawnEntityPrefab(Resource.Load(\"{C7505F1DD25292B3}Prefabs/Characters/HeadGear/Hat_Boonie_US_01/Eyepatch.et\"), GetGame().GetWorld(), spawnParams);"\
 "		SCR_InventoryStorageManagerComponent inventoryManager = SCR_InventoryStorageManagerComponent.Cast(entity.FindComponent(SCR_InventoryStorageManagerComponent));"\
 "		SCR_CharacterInventoryStorageComponent inventory = SCR_CharacterInventoryStorageComponent.Cast(entity.FindComponent(SCR_CharacterInventoryStorageComponent));"\
 "		inventoryManager.TryReplaceItem(resourceSpawned, inventory, 9);"\
 "	}"\
 "	"\
 "	void SetVisIdentityOcelot(IEntity entity)"\
 "	{"\
 "		SCR_CharacterIdentityComponent identityComp = SCR_CharacterIdentityComponent.Cast(entity.FindComponent(SCR_CharacterIdentityComponent));"\
 "		VisualIdentity visIdentity = identityComp.GetIdentity().GetVisualIdentity();"\
 "		visIdentity.SetHead(\"{9611A700F48E869B}Prefabs/Characters/Heads/Head_WhiteHead_04.et\");"\
 "		identityComp.CommitChanges();"\
 "		#ifdef WORKBENCH"\
 "		#else"\
 "		if (!System.IsConsoleApp())"\
 "			return;"\
 "		#endif"\
 "		EntitySpawnParams spawnParams = new EntitySpawnParams();"\
 "		entity.GetTransform(spawnParams.Transform);"\
 "		IEntity resourceSpawned = GetGame().SpawnEntityPrefab(Resource.Load(\"{E738B6B438B5A68F}Prefabs/Characters/HeadGear/Hat_Boonie_US_01/Ocelot_Scarf.et\"), GetGame().GetWorld(), spawnParams);"\
 "		SCR_InventoryStorageManagerComponent inventoryManager = SCR_InventoryStorageManagerComponent.Cast(entity.FindComponent(SCR_InventoryStorageManagerComponent));"\
 "		SCR_CharacterInventoryStorageComponent inventory = SCR_CharacterInventoryStorageComponent.Cast(entity.FindComponent(SCR_CharacterInventoryStorageComponent));"\
 "		inventoryManager.TryReplaceItem(resourceSpawned, inventory, 12);"\
 "	}"\
 "	"\
 "	void AddArmBand(IEntity entity)"\
 "	{"\
 "		EntitySpawnParams spawnParams = new EntitySpawnParams();"\
 "		entity.GetTransform(spawnParams.Transform);"\
 "		IEntity resourceSpawned = GetGame().SpawnEntityPrefab(Resource.Load(\"{BC431B58DB4BCEF8}Prefabs/Characters/Accessories/Armband/DiamondDogs_Armband.et\"), GetGame().GetWorld(), spawnParams);"\
 "		SCR_InventoryStorageManagerComponent inventoryManager = SCR_InventoryStorageManagerComponent.Cast(entity.FindComponent(SCR_InventoryStorageManagerComponent));"\
 "		SCR_CharacterInventoryStorageComponent inventory = SCR_CharacterInventoryStorageComponent.Cast(entity.FindComponent(SCR_CharacterInventoryStorageComponent));"\
 "		inventoryManager.TryReplaceItem(resourceSpawned, inventory, 8);"\
 "	}"
 OnControllableSpawned ""\
 "		super.OnControllableSpawned(entity);"\
 "		if (entity.GetPrefabData().GetPrefabName() == \"{B3182F73DBEACB7B}Prefabs/Characters/Factions/BLUFOR/CRF_GS_BLUFOR_COY_P.et\")"\
 "			GetGame().GetCallqueue().Call(SetVisIdentityBigBoss, entity);"\
 "		"\
 "		if (entity.GetPrefabData().GetPrefabName() == \"{A53B8AB60784E018}Prefabs/Characters/Factions/INDFOR/CRF_GS_INDFOR_COY_P.et\")"\
 "			GetGame().GetCallqueue().Call(SetVisIdentityOcelot, entity);"\
 "		"\
 "		#ifdef WORKBENCH"\
 "		#else"\
 "		if (!System.IsConsoleApp())"\
 "			return;"\
 "		#endif"\
 "		"\
 "		if (entity.GetPrefabData().GetPrefabName().Contains(\"BLUFOR\") || entity.GetPrefabData().GetPrefabName().Contains(\"INDFOR\") )"\
 "			GetGame().GetCallqueue().Call(AddArmBand, entity);"\
 "	"
 m_iTimeLimitMinutes 60
 m_aMissionDescriptors {
  CRF_MissionDescriptor "{644250503DF684C0}" {
   m_sTextData "[READ THE ADMIN TAB]"\
   ""\
   "“Boss, a Soviet Spetsnaz platoon has been sighted in the Central Highlands of Vietnam. Their commander’s directing counter-insurgency against local guerrillas. If he isn’t removed, the Soviets will gain a foothold here."\
   "Your mission is to capture that commander alive. You’ll lead one of our platoons, while Ocelot takes a section from the Security Team. But remember—the Security Team’s still on Soviet radios, your unit’s on American. You won’t be able to talk to each other directly in the field."\
   "Intel says the commander will have an extraction in forty minutes. If you don’t secure him before then, we'll have to intercept him on his way out."\
   ""\
   "Bring him back, Boss.”"\
   ""\
   "BLUFOR Composition: Infantry"\
   "BLUFOR Assets:"\
   "MMG"\
   "Recon Team"\
   ""\
   "OPFOR Composition: Infantry"\
   "OPFOR Assets:"\
   "Mortar"\
   "MMG"\
   ""\
   "Time: 60"\
   ""\
   "Weather: Clear"
  }
  CRF_MissionDescriptor "{64425051F2E00216}" {
   m_sTextData "- Capture the Soviet Platoon Leader alive."\
   "- Ensure he does not escape."\
   ""\
   "- Utilize the UAZs for your respawns to cut off the target if he tries to flee"
  }
  CRF_MissionDescriptor "{64425051B9B5AF67}" {
   m_sTextData "- Do not let the Platoon Leader die."\
   "- Do not let the Platoon Leader be captured."\
   "- Defend until extraction. then get the PL out of here."
  }
  CRF_MissionDescriptor "{644250519BE30999}" {
   m_sTextData "- Capture the Soviet Platoon Leader alive."\
   "- Ensure he does not escape."
  }
  CRF_MissionDescriptor "{6442505149CF6C93}" {
   m_sTextData "BLUFOR and INDFOR are friendly but have no comms together."\
   ""\
   "After 40 minutes an extraction location will appear on the map, you will have to prevent the HVT from reaching that area. There will be a respawn wave at 40 minutes when the HVT gets his extraction location."
  }
 }
 m_iFactionOneRatio 2
