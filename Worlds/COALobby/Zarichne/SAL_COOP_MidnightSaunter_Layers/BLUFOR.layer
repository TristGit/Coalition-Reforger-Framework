$grp CRF_MissionMarker : "{821DA53A26209581}PrefabsEditable/Markers/ObjectiveMarkers/GlobalObjectiveMarker.et" {
 {
  coords 1705.798 9.517 1278.768
  m_sDescription "2S1 Battery"
  m_sMissionMarkerDescription "Drone Operators in the region have reported a 2S1 Battery staged here stupidly close to the front, they've been shelling rearward positions for the last week while we've been trying to push to the river. Go in and destroy them with CAS."
  m_aMissionMarkerImages {
   "{76A20DD77E839EFC}CRF Images/BriefingImages/Salami/MidnightSaunter/OBJ1.edds"
  }
 }
 {
  coords 714.626 13.396 1874.492
  m_sDescription "2S1 Battery"
  m_sMissionMarkerDescription "This battery in the rear recently got here to back up the other 2S1s causing havoc on our NATO allies, we've been tasked in to hunt these down as well and blow them up."
  m_aMissionMarkerImages {
   "{284A2494C10E10F3}CRF Images/BriefingImages/Salami/MidnightSaunter/OBJ2.edds"
  }
 }
 {
  coords 2068.625 7.774 2254.911
  m_sDescription "2S1 Battery"
  m_sMissionMarkerDescription "We've been tasked as well with setting up a beach head on the other side of this bridge for the Battalion level breakthrough to be conducted tomorrow morning. We must capture these trenches that prevent our infantry from crossing."
  m_aMissionMarkerImages {
   "{DC42630CCCD37887}CRF Images/BriefingImages/Salami/MidnightSaunter/OBJ3.edds"
  }
 }
}