BaseGameTriggerEntity flightGenerator {
 coords 2268.416 7.944 2363.231
 userScript "	bool m_bSafeStartInit = false;"\
 "	void InitPlane()"\
 "	{"\
 "		vector start = \"0 900 5000\";"\
 "		vector end = \"5000 900 0\";"\
 "		float angle = 135;"\
 "		vector greenLight = \"2500 900 2500\";"\
 "		vector flightData[4];"\
 "		flightData[0] = start;"\
 "		flightData[3] = end;"\
 "		flightData[2] = greenLight;"\
 "		ref CRF_AirdropObject flight = new CRF_AirdropObject(\"BLUFOR\", \"{D35A20947FE9E130}PrefabsEditable/Auto/Props/c130.et\", flightData, angle);"\
 "		CRF_AirdropManager.GetInstance().InitFlight(flight);"\
 "		delete this;"\
 "	}"
 TriggerShapeType Sphere
 PeriodicQueries 1
 UpdatePeriod 5
 OnQueryFinished ""\
 "		if (!Replication.IsServer())"\
 "		{"\
 "			delete this;"\
 "			return;"\
 "		}"\
 "		if (!m_bSafeStartInit)"\
 "		{"\
 "			m_bSafeStartInit = CRF_SafestartManager.GetInstance().GetSafestartStatus();	"\
 "			return;"\
 "		}"\
 "		else"\
 "		{"\
 "			if (!CRF_SafestartManager.GetInstance().GetSafestartStatus())"\
 "				InitPlane();"\
 "		}"\
 "	"
}
